<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Story de <%= story.auteur %></title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/story.css">
  <link rel="stylesheet" href="/css/mobile.css">
</head>
<body>

  <div class="story-page">

    <div class="story-container">

      <!-- HEADER -->
      <div class="story-header">
        <div class="story-user">
          <div class="story-user-avatar"><i class="fas fa-user"></i></div>
          <div>
            <strong><%= story.auteur %></strong>
            <span><%= new Date(story.createdAt).toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' }) %></span>
          </div>
        </div>
        <div class="story-header-actions">
          <% if (story.auteurId.toString() === userId) { %>
            <form action="/story/delete/<%= story._id %>" method="POST">
              <button class="btn-story-delete"><i class="fas fa-trash"></i></button>
            </form>
          <% } %>
          <a href="/home" class="btn-story-close"><i class="fas fa-times"></i></a>
        </div>
      </div>

      <!-- BARRE DE PROGRESSION -->
      <div class="story-progress">
        <div class="story-progress-bar" id="progressBar"></div>
      </div>

      <!-- IMAGE -->
      <img src="<%= story.photo %>" class="story-image" alt="Story" />

      <!-- VUES -->
      <div class="story-footer">
        <span><i class="fas fa-eye"></i> <%= story.vues.length %> vue<%= story.vues.length > 1 ? 's' : '' %></span>
        <span class="story-expire">Expire dans 24h</span>
      </div>

    </div>

  </div>

  <script>
    // Barre de progression 5 secondes
    const bar = document.getElementById("progressBar");
    let width = 0;
    const interval = setInterval(() => {
      width += 0.5;
      bar.style.width = width + "%";
      if (width >= 100) {
        clearInterval(interval);
        window.location.href = "/home";
      }
    }, 25);
  </script>

</body>
</html>