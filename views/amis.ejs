<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mumpower — Mes amis</title>
  <link rel="stylesheet" href="/css/home.css">
  <link rel="stylesheet" href="/css/amis.css">
  <link rel="stylesheet" href="/css/mobile.css">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>

  <aside class="sidebar">
    <div class="sidebar-logo">mumpower</div>
    <nav>
      <a href="/home" class="nav-item"><i class="fas fa-home"></i><span>Accueil</span></a>
      <a href="/recherche" class="nav-item"><i class="fas fa-search"></i><span>Recherche</span></a>
      <a href="/marketplace" class="nav-item"><i class="fas fa-store"></i><span>Vente</span></a>
      <a href="/messages" class="nav-item"><i class="fas fa-comment-dots"></i><span>Messages</span></a>
      <a href="/notifications" class="nav-item"><i class="fas fa-bell"></i><span>Notifications</span></a>
      <a href="/profil" class="nav-item"><i class="fas fa-user"></i><span>Mon profil</span></a>
      <a href="/amis" class="nav-item active"><i class="fas fa-user-friends"></i><span>Amis</span></a>
      <a href="/parametres" class="nav-item"><i class="fas fa-cog"></i><span>Paramètres</span></a>
    </nav>
    <div class="sidebar-bottom">
      <a href="/aide" class="nav-item aide"><i class="fas fa-shield-heart"></i><span>Aide discrète</span></a>
      <a href="/logout" class="nav-item logout"><i class="fas fa-sign-out-alt"></i><span>Déconnexion</span></a>
    </div>
  </aside>

  <main class="amis-main">

    <% if (demandesRecues.length > 0) { %>
    <div class="amis-section">
      <h2><i class="fas fa-user-clock"></i> Demandes reçues <span class="badge"><%= demandesRecues.length %></span></h2>
      <div class="amis-grid">
        <% demandesRecues.forEach(function(u) { %>
          <div class="ami-card">
            <div class="ami-avatar">
              <% if (u.avatar) { %>
                <img src="<%= u.avatar %>" alt="<%= u.nom %>" />
              <% } else { %>
                <i class="fas fa-user"></i>
              <% } %>
            </div>
            <div class="ami-info">
              <strong><%= u.nom %></strong>
            </div>
            <div class="ami-actions">
              <form action="/ami/accepter/<%= u._id %>" method="POST">
                <button class="btn-accepter"><i class="fas fa-check"></i> Accepter</button>
              </form>
              <form action="/ami/refuser/<%= u._id %>" method="POST">
                <button class="btn-refuser"><i class="fas fa-times"></i> Refuser</button>
              </form>
            </div>
          </div>
        <% }); %>
      </div>
    </div>
    <% } %>

    <div class="amis-section">
      <h2><i class="fas fa-heart"></i> Mes amis <span class="badge"><%= amis.length %></span></h2>
      <% if (amis.length === 0) { %>
        <div class="amis-empty">
          <i class="fas fa-user-friends"></i>
          <h3>Pas encore d'amis</h3>
          <p>Recherche des membres et envoie-leur une demande 💜</p>
          <a href="/recherche" class="btn-recherche"><i class="fas fa-search"></i> Rechercher des membres</a>
        </div>
      <% } else { %>
        <div class="amis-grid">
          <% amis.forEach(function(u) { %>
            <div class="ami-card">
              <a href="/profil/<%= u._id %>" class="ami-link">
                <div class="ami-avatar">
                  <% if (u.avatar) { %>
                    <img src="<%= u.avatar %>" alt="<%= u.nom %>" />
                  <% } else { %>
                    <i class="fas fa-user"></i>
                  <% } %>
                </div>
                <div class="ami-info">
                  <strong><%= u.nom %></strong>
                </div>
              </a>
              <div class="ami-actions">
                <a href="/messages/<%= u._id %>" class="btn-message"><i class="fas fa-comment-dots"></i> Message</a>
                <form action="/ami/supprimer/<%= u._id %>" method="POST">
                  <button class="btn-supprimer"><i class="fas fa-user-minus"></i></button>
                </form>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>

    <% if (demandesEnvoyees.length > 0) { %>
    <div class="amis-section">
      <h2><i class="fas fa-paper-plane"></i> Demandes envoyées</h2>
      <div class="amis-grid">
        <% demandesEnvoyees.forEach(function(u) { %>
          <div class="ami-card">
            <div class="ami-avatar">
              <% if (u.avatar) { %>
                <img src="<%= u.avatar %>" alt="<%= u.nom %>" />
              <% } else { %>
                <i class="fas fa-user"></i>
              <% } %>
            </div>
            <div class="ami-info">
              <strong><%= u.nom %></strong>
              <span class="en-attente">En attente...</span>
            </div>
          </div>
        <% }); %>
      </div>
    </div>
    <% } %>

  </main>

  <div class="toast" id="toast">
    <i class="fas fa-bell"></i>
    <span id="toast-msg"></span>
  </div>

  <script src="/socket.io/socket.io.js"></script>
  <script>
    const socket = io();
    socket.emit("rejoindre", "<%= userId %>");
    socket.on("nouvelle-notif", function(data) {
      const toast = document.getElementById("toast");
      document.getElementById("toast-msg").textContent = data.message;
      toast.classList.add("show");
      setTimeout(() => toast.classList.remove("show"), 4000);
    });
  </script>

</body>
</html>