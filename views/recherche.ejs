<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mumpower — Recherche</title>
  <link rel="stylesheet" href="/css/home.css">
  <link rel="stylesheet" href="/css/recherche.css">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>

  <aside class="sidebar">
    <div class="sidebar-logo">mumpower</div>
    <nav>
      <a href="/home" class="nav-item"><i class="fas fa-home"></i><span>Accueil</span></a>
      
      <a href="/amis" class="nav-item"><i class="fas fa-user-friends"></i><span>Amis</span></a>
      <a href="/recherche" class="nav-item active"><i class="fas fa-search"></i><span>Recherche</span></a>
      <a href="/marketplace" class="nav-item"><i class="fas fa-store"></i><span>Vente</span></a>
      <a href="/messages" class="nav-item"><i class="fas fa-comment-dots"></i><span>Messages</span></a>
      <a href="/notifications" class="nav-item"><i class="fas fa-bell"></i><span>Notifications</span></a>
      <a href="/profil" class="nav-item"><i class="fas fa-user"></i><span>Mon profil</span></a>
      <a href="/parametres" class="nav-item"><i class="fas fa-cog"></i><span>Paramètres</span></a>
    </nav>
    <div class="sidebar-bottom">
      <a href="/aide" class="nav-item aide"><i class="fas fa-shield-heart"></i><span>Aide discrète</span></a>
      <a href="/logout" class="nav-item logout"><i class="fas fa-sign-out-alt"></i><span>Déconnexion</span></a>
    </div>
  </aside>

  <main class="recherche-main">

    <!-- BARRE DE RECHERCHE -->
    <div class="recherche-bar">
      <form action="/recherche" method="GET">
        <div class="search-input-wrap">
          <i class="fas fa-search"></i>
          <input
            type="text"
            name="q"
            placeholder="Recherche un membre, une publication, un article..."
            value="<%= q %>"
            autofocus
          />
          <% if (q) { %>
            <a href="/recherche" class="search-clear"><i class="fas fa-times"></i></a>
          <% } %>
        </div>
        <button type="submit" class="btn-search">Rechercher</button>
      </form>
    </div>

    <% if (!q) { %>
      <!-- ÉTAT INITIAL -->
      <div class="recherche-empty">
        <i class="fas fa-search"></i>
        <h3>Recherche sur Mumpower</h3>
        <p>Trouve des membres, des publications ou des articles 💜</p>
      </div>

    <% } else { %>

      <!-- RÉSULTATS MEMBRES -->
      <% if (users.length > 0) { %>
        <div class="result-section">
          <h2><i class="fas fa-users"></i> Membres (<%= users.length %>)</h2>
          <div class="users-results">
            <% users.forEach(function(user) { %>
              <div class="user-result-card">
                <div class="user-result-avatar">
                  <% if (user.avatar) { %>
                    <img src="<%= user.avatar %>" alt="<%= user.nom %>" />
                  <% } else { %>
                    <i class="fas fa-user"></i>
                  <% } %>
                </div>
                <div class="user-result-info">
                  <strong><%= user.nom %></strong>
                  <% if (user.ville) { %>
                    <span><i class="fas fa-map-marker-alt"></i> <%= user.ville %></span>
                  <% } %>
                  <% if (user.bio) { %>
                    <p><%= user.bio.length > 60 ? user.bio.substring(0, 60) + '...' : user.bio %></p>
                  <% } %>
                </div>
               <a href="/profil/<%= user._id %>" class="btn-voir-profil">
  <i class="fas fa-user"></i> Voir le profil
</a>
<a href="/messages/<%= user._id %>" class="btn-contacter-user">
  <i class="fas fa-comment-dots"></i> Message
</a>
              </div>
            <% }); %>
          </div>
        </div>
      <% } %>

      <!-- RÉSULTATS PUBLICATIONS -->
      <% if (posts.length > 0) { %>
        <div class="result-section">
          <h2><i class="fas fa-file-alt"></i> Publications (<%= posts.length %>)</h2>
          <div class="posts-results">
            <% posts.forEach(function(post) { %>
              <div class="post-result-card">
                <div class="post-result-avatar"><i class="fas fa-user"></i></div>
                <div class="post-result-content">
                  <strong><%= post.auteur %></strong>
                  <p><%= post.content %></p>
                  <span><%= new Date(post.createdAt).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long' }) %></span>
                </div>
              </div>
            <% }); %>
          </div>
        </div>
      <% } %>

      <!-- RÉSULTATS ARTICLES -->
      <% if (articles.length > 0) { %>
        <div class="result-section">
          <h2><i class="fas fa-store"></i> Articles en vente (<%= articles.length %>)</h2>
          <div class="articles-results">
            <% articles.forEach(function(article) { %>
              <a href="/marketplace" class="article-result-card">
                <div class="article-result-photo">
                  <% if (article.photo) { %>
                    <img src="<%= article.photo %>" alt="<%= article.titre %>" />
                  <% } else { %>
                    <i class="fas fa-image"></i>
                  <% } %>
                </div>
                <div class="article-result-info">
                  <strong><%= article.titre %></strong>
                  <span class="article-result-prix"><%= article.prix %> €</span>
                  <p><%= article.description.length > 60 ? article.description.substring(0, 60) + '...' : article.description %></p>
                </div>
              </a>
            <% }); %>
          </div>
        </div>
      <% } %>

      <!-- AUCUN RÉSULTAT -->
      <% if (users.length === 0 && posts.length === 0 && articles.length === 0) { %>
        <div class="recherche-empty">
          <i class="fas fa-search"></i>
          <h3>Aucun résultat pour "<%= q %>"</h3>
          <p>Essaie avec d'autres mots clés 💜</p>
        </div>
      <% } %>

    <% } %>

  </main>

</body>
</html>