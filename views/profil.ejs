<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mumpower — Mon profil</title>
  <link rel="stylesheet" href="/css/home.css">
  <link rel="stylesheet" href="/css/profil.css">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>

  <aside class="sidebar">
        <div class="sidebar-logo">mumpower</div>
    <nav>
      <a href="/home" class="nav-item"><i class="fas fa-home"></i><span>Accueil</span></a>
      <a href="/recherche" class="nav-item active"><i class="fas fa-search"></i><span>Recherche</span></a>
      <a href="/marketplace" class="nav-item"><i class="fas fa-store"></i><span>Vente</span></a>
      <a href="/messages" class="nav-item"><i class="fas fa-comment-dots"></i><span>Messages</span></a>
      <a href="/notifications" class="nav-item"><i class="fas fa-bell"></i><span>Notifications</span></a>
      <a href="/profil" class="nav-item"><i class="fas fa-user"></i><span>Mon profil</span></a>
      <a href="/parametres" class="nav-item"><i class="fas fa-cog"></i><span>Paramètres</span></a>
    </nav>
    <div class="sidebar-bottom">
      <a href="/aide" class="nav-item aide"><i class="fas fa-shield-heart"></i><span>Aide discrète</span></a>
      <a href="/logout" class="nav-item logout"><i class="fas fa-sign-out-alt"></i><span>Déconnexion</span></a>
    </div>
  </aside>

  <main class="profil-main">

    <!-- CARTE PROFIL -->
    <div class="profil-card">
      <div class="profil-avatar-wrap">
        <% if (user.avatar) { %>
          <img src="<%= user.avatar %>" class="profil-avatar-img" />
        <% } else { %>
          <div class="profil-avatar-default"><i class="fas fa-user"></i></div>
        <% } %>
        <button class="btn-edit-avatar" onclick="toggleModal()">
          <i class="fas fa-camera"></i>
        </button>
      </div>

      <div class="profil-info">
        <h1><%= user.nom %></h1>
        <% if (user.bio) { %>
          <p class="profil-bio"><%= user.bio %></p>
        <% } else { %>
          <p class="profil-bio vide">Ajoute une bio 💜</p>
        <% } %>
        <div class="profil-details">
          <% if (user.ville) { %>
            <span><i class="fas fa-map-marker-alt"></i> <%= user.ville %></span>
          <% } %>
          <% if (user.enfants) { %>
            <span><i class="fas fa-baby"></i> <%= user.enfants %></span>
          <% } %>
          <span><i class="fas fa-calendar"></i> Membre depuis <%= new Date(user.createdAt).toLocaleDateString('fr-FR', { month: 'long', year: 'numeric' }) %></span>
        </div>
      </div>

      <button class="btn-modifier" onclick="toggleModal()">
        <i class="fas fa-pen"></i> Modifier le profil
      </button>
    </div>

    <!-- STATS -->
    <div class="profil-stats">
      <div class="stat-card">
        <strong><%= posts.length %></strong>
        <span>Publications</span>
      </div>
      <div class="stat-card">
        <strong><%= articles.length %></strong>
        <span>Articles en vente</span>
      </div>
      <div class="stat-card">
        <strong>0</strong>
        <span>Abonnés</span>
      </div>
    </div>

    <!-- ONGLETS -->
    <div class="profil-tabs">
      <button class="tab active" onclick="showTab(this, 'tab-posts')">
        <i class="fas fa-th"></i> Publications
      </button>
      <button class="tab" onclick="showTab(this, 'tab-vente')">
        <i class="fas fa-store"></i> Mes annonces
      </button>
    </div>

    <!-- PUBLICATIONS -->
    <div id="tab-posts" class="tab-content">
      <% if (posts.length === 0) { %>
        <div class="tab-empty">
          <i class="fas fa-seedling"></i>
          <p>Aucune publication pour l'instant</p>
        </div>
      <% } else { %>
        <% posts.forEach(post => { %>
          <div class="post-card">
            <div class="post-header">
              <div class="post-avatar"><i class="fas fa-user"></i></div>
              <div class="post-meta">
                <strong><%= post.auteur %></strong>
                <span><%= new Date(post.createdAt).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long' }) %></span>
              </div>
              <form action="/post/delete/<%= post._id %>" method="POST" style="margin-left:auto;">
                <button class="btn-delete"><i class="fas fa-trash"></i></button>
              </form>
            </div>
            <p class="post-content"><%= post.content %></p>
          </div>
        <% }) %>
      <% } %>
    </div>

    <!-- ANNONCES -->
    <div id="tab-vente" class="tab-content" style="display:none;">
      <% if (articles.length === 0) { %>
        <div class="tab-empty">
          <i class="fas fa-store"></i>
          <p>Aucune annonce pour l'instant</p>
        </div>
      <% } else { %>
        <div class="mini-grid">
          <% articles.forEach(article => { %>
            <div class="mini-article">
              <div class="mini-photo">
                <% if (article.photo) { %>
                  <img src="<%= article.photo %>" alt="<%= article.titre %>" />
                <% } else { %>
                  <div class="no-photo"><i class="fas fa-image"></i></div>
                <% } %>
              </div>
              <div class="mini-info">
                <strong><%= article.titre %></strong>
                <span><%= article.prix %> €</span>
              </div>
              <form action="/marketplace/delete/<%= article._id %>" method="POST">
                <button class="btn-delete"><i class="fas fa-trash"></i></button>
              </form>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

  </main>

  <!-- MODAL MODIFIER PROFIL -->
  <div class="modal-overlay" id="modal" onclick="closeModal(event)">
    <div class="modal">
      <div class="modal-header">
        <h2>Modifier le profil</h2>
        <button onclick="toggleModal()"><i class="fas fa-times"></i></button>
      </div>
      <form action="/profil/modifier" method="POST" enctype="multipart/form-data">
        <div class="form-group">
          <label>Photo de profil</label>
          <input type="file" name="avatar" accept="image/*" />
        </div>
        <div class="form-group">
          <label>Bio</label>
          <textarea name="bio" placeholder="Parle de toi..."><%= user.bio %></textarea>
        </div>
        <div class="form-group">
          <label>Ville</label>
          <input type="text" name="ville" placeholder="Ex: Paris" value="<%= user.ville %>" />
        </div>
        <div class="form-group">
          <label>Mes enfants</label>
          <input type="text" name="enfants" placeholder="Ex: 2 enfants, 3 et 6 ans" value="<%= user.enfants %>" />
        </div>
        <button type="submit" class="btn-submit">Enregistrer</button>
      </form>
    </div>
  </div>

  <script>
    function toggleModal() {
      document.getElementById("modal").classList.toggle("active");
    }
    function closeModal(e) {
      if (e.target.id === "modal") toggleModal();
    }
    function showTab(btn, tabId) {
      document.querySelectorAll(".tab").forEach(t => t.classList.remove("active"));
      document.querySelectorAll(".tab-content").forEach(t => t.style.display = "none");
      btn.classList.add("active");
      document.getElementById(tabId).style.display = "block";
    }
  </script>

</body>
</html>