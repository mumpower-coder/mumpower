<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mumpower — La plateforme des mamans & futures mamans modernes</title>
  <link rel="stylesheet" href="/css/landing.css">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>

  <!-- NAV -->
  <nav class="nav">
    <div class="nav-logo">mumpower</div>
    <div class="nav-links">
      <a href="#concept">Le concept</a>
      <a href="#fonctionnalites">Fonctionnalités</a>
      <a href="#securite">Sécurité</a>
    </div>
    <div class="nav-cta">
      <a href="/" class="btn-nav-login">Se connecter</a>
      <a href="/register" class="btn-nav-register">Rejoindre</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg">
      <div class="blob blob-1"></div>
      <div class="blob blob-2"></div>
      <div class="blob blob-3"></div>
    </div>
    <div class="hero-content">
      <div class="hero-badge">
        <i class="fas fa-shield-heart"></i> Plateforme sécurisée & bienveillante
      </div>
      <h1>La première plateforme <em>pensée</em> pour les mamans & futures mamans modernes</h1>
      <p>Échangez, vendez, trouvez des services et soyez soutenus au sein d'une communauté de mamans bienveillantes.</p>
      <div class="hero-buttons">
        <a href="/register" class="btn-primary">
          Rejoindre gratuitement <i class="fas fa-arrow-right"></i>
        </a>
        <a href="#concept" class="btn-secondary">
          Découvrir <i class="fas fa-chevron-down"></i>
        </a>
      </div>
      <div class="hero-stats">
        <div class="stat">
          <strong>100%</strong>
          <span>Gratuit</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <strong>24h/24</strong>
          <span>Module aide</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <strong>💜</strong>
          <span>Bienveillant</span>
        </div>
      </div>
    </div>
    <div class="hero-visual">
      <div class="phone-mockup">
        <div class="phone-screen">
          <div class="phone-header">
            <span class="phone-logo">mumpower</span>
          </div>
          <div class="phone-stories">
            <div class="phone-story s1"></div>
            <div class="phone-story s2"></div>
            <div class="phone-story s3"></div>
            <div class="phone-story s4"></div>
          </div>
          <div class="phone-post">
            <div class="phone-post-avatar"></div>
            <div class="phone-post-lines">
              <div class="line l1"></div>
              <div class="line l2"></div>
            </div>
          </div>
          <div class="phone-post">
            <div class="phone-post-avatar pa2"></div>
            <div class="phone-post-lines">
              <div class="line l3"></div>
              <div class="line l4"></div>
            </div>
          </div>
          <div class="phone-market">
            <div class="phone-market-item mi1"></div>
            <div class="phone-market-item mi2"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CONCEPT -->
  <section class="concept" id="concept">
    <div class="container">
      <div class="section-label">Le concept</div>
      <h2>Tout ce dont tu as besoin, <em>au même endroit</em></h2>
      <p class="section-desc">Mumpower réunit en une seule plateforme tout ce dont les mamans ont besoin au quotidien.</p>
      <div class="concept-grid">
        <div class="concept-card">
          <div class="concept-icon"><i class="fas fa-users"></i></div>
          <h3>Réseau social</h3>
          <p>Publie, partage, commente et connecte-toi avec d'autres mamans qui te comprennent vraiment.</p>
        </div>
        <div class="concept-card featured">
          <div class="concept-icon"><i class="fas fa-store"></i></div>
          <h3>Marketplace</h3>
          <p>Vends et achète des articles pour enfants entre parents de la communauté. Simple, rapide, sécurisé.</p>
        </div>
        <div class="concept-card">
          <div class="concept-icon"><i class="fas fa-comment-dots"></i></div>
          <h3>Messagerie</h3>
          <p>Discute en privé avec les membres de la communauté, les vendeurs et les prestataires de services.</p>
        </div>
        <div class="concept-card">
          <div class="concept-icon"><i class="fas fa-photo-video"></i></div>
          <h3>Stories</h3>
          <p>Partage des moments de ta vie parentale avec des stories éphémères qui disparaissent en 24h.</p>
        </div>
        <div class="concept-card">
          <div class="concept-icon"><i class="fas fa-bell"></i></div>
          <h3>Notifications</h3>
          <p>Reste informée en temps réel de toutes les interactions sur ta communauté.</p>
        </div>
        <div class="concept-card special">
          <div class="concept-icon"><i class="fas fa-shield-heart"></i></div>
          <h3>Aide discrète</h3>
          <p>Un espace sécurisé et confidentiel avec les numéros d'urgence pour celles qui en ont besoin.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FONCTIONNALITÉS -->
  <section class="features" id="fonctionnalites">
    <div class="container">
      <div class="section-label">Fonctionnalités</div>
      <h2>Une expérience <em>pensée</em> pour vous</h2>
      <div class="features-list">

        <div class="feature-row">
          <div class="feature-visual fv1">
            <i class="fas fa-store"></i>
            <div class="feature-tag">Vente</div>
          </div>
          <div class="feature-text">
            <h3>Vends et achète entre parents</h3>
            <p>La marketplace Mumpower te permet de vendre facilement tes articles pour enfants avec photos, descriptions et prix. Filtre par catégorie, contacte directement le vendeur.</p>
            <ul>
              <li><i class="fas fa-check"></i> Upload de photos</li>
              <li><i class="fas fa-check"></i> Filtres par catégorie</li>
              <li><i class="fas fa-check"></i> Contact direct vendeur</li>
            </ul>
          </div>
        </div>

        <div class="feature-row reverse">
          <div class="feature-visual fv2">
            <i class="fas fa-comment-dots"></i>
            <div class="feature-tag">Messages</div>
          </div>
          <div class="feature-text">
            <h3>Messagerie privée instantanée</h3>
            <p>Discute en temps réel avec les membres de la communauté. Tes conversations sont privées et sécurisées.</p>
            <ul>
              <li><i class="fas fa-check"></i> Messages en temps réel</li>
              <li><i class="fas fa-check"></i> Notifications instantanées</li>
              <li><i class="fas fa-check"></i> 100% privé</li>
            </ul>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- SÉCURITÉ -->
  <section class="securite" id="securite">
    <div class="container">
      <div class="securite-content">
        <div class="section-label light">Sécurité</div>
        <h2>Ta sécurité est notre <em>priorité</em></h2>
        <p>Mumpower a été conçu dès le départ avec la sécurité et la bienveillance au cœur de chaque décision.</p>
        <div class="securite-points">
          <div class="securite-point">
            <i class="fas fa-lock"></i>
            <div>
              <strong>Données chiffrées</strong>
              <span>Tes mots de passe et données personnelles sont protégés</span>
            </div>
          </div>
          <div class="securite-point">
            <i class="fas fa-shield-heart"></i>
            <div>
              <strong>Module aide discrète</strong>
              <span>Un espace sécurisé avec quitter rapidement en un clic</span>
            </div>
          </div>
          <div class="securite-point">
            <i class="fas fa-eye-slash"></i>
            <div>
              <strong>Navigation protégée</strong>
              <span>Conseils pour protéger ta navigation et ton historique</span>
            </div>
          </div>
          <div class="securite-point">
            <i class="fas fa-heart"></i>
            <div>
              <strong>Communauté bienveillante</strong>
              <span>Modération active pour un espace sain et respectueux</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="cta-final">
    <div class="container">
      <div class="cta-card">
        <div class="cta-blobs">
          <div class="cta-blob cb1"></div>
          <div class="cta-blob cb2"></div>
        </div>
        <h2>Prête à rejoindre la communauté ?</h2>
        <p>Mumpower est gratuit, toujours. Rejoins des milliers de mamans qui s'entraident chaque jour.</p>
        <a href="/register" class="btn-primary large">
          Créer mon compte gratuitement <i class="fas fa-arrow-right"></i>
        </a>
        <p class="cta-sub">Déjà membre ? <a href="/">Se connecter</a></p>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container">
      <div class="footer-logo">mumpower</div>
      <p>La plateforme des mamans et futures mamans modernes 💜</p>
      <div class="footer-links">
        <a href="/aide">Aide discrète</a>
        <a href="/register">S'inscrire</a>
        <a href="/">Se connecter</a>
      </div>
      <p class="footer-copy">© 2026 Mumpower — Fait avec 💜</p>
    </div>
  </footer>

  <script>
    // Smooth scroll
    document.querySelectorAll('a[href^="#"]').forEach(a => {
      a.addEventListener('click', e => {
        e.preventDefault();
        document.querySelector(a.getAttribute('href')).scrollIntoView({ behavior: 'smooth' });
      });
    });

    // Animation au scroll
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) e.target.classList.add('visible');
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.concept-card, .feature-row, .securite-point').forEach(el => {
      observer.observe(el);
    });
  </script>

</body>
</html>