<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mumpower — Espace sécurisé</title>
  <link rel="stylesheet" href="/css/home.css">
  <link rel="stylesheet" href="/css/aide.css">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>

  <!-- BOUTON QUITTER RAPIDEMENT -->
  <button class="btn-quitter" onclick="quitterVite()">
    <i class="fas fa-times"></i> Quitter rapidement
  </button>

  <aside class="sidebar">
    <div class="sidebar-logo">mumpower</div>
    <nav>
      <a href="/home" class="nav-item"><i class="fas fa-home"></i><span>Accueil</span></a>
      <a href="/recherche" class="nav-item"><i class="fas fa-search"></i><span>Recherche</span></a>
      <a href="/marketplace" class="nav-item"><i class="fas fa-store"></i><span>Vente</span></a>
      <a href="/messages" class="nav-item"><i class="fas fa-comment-dots"></i><span>Messages</span></a>
      <a href="/notifications" class="nav-item"><i class="fas fa-bell"></i><span>Notifications</span></a>
      <a href="/profil" class="nav-item"><i class="fas fa-user"></i><span>Mon profil</span></a>
      <a href="/parametres" class="nav-item"><i class="fas fa-cog"></i><span>Paramètres</span></a>
    </nav>
    <div class="sidebar-bottom">
      <a href="/aide" class="nav-item aide active"><i class="fas fa-shield-heart"></i><span>Aide discrète</span></a>
      <a href="/logout" class="nav-item logout"><i class="fas fa-sign-out-alt"></i><span>Déconnexion</span></a>
    </div>
  </aside>

  <main class="aide-main">

    <!-- HERO -->
    <div class="aide-hero">
      <div class="aide-hero-icon"><i class="fas fa-shield-heart"></i></div>
      <h1>Tu n'es pas seule</h1>
      <p>Cet espace est confidentiel et sécurisé. Prends le temps qu'il te faut. Des personnes sont là pour t'aider.</p>
    </div>

    <!-- URGENCE -->
    <div class="aide-urgence">
      <div class="urgence-badge"><i class="fas fa-exclamation-triangle"></i> En danger immédiat ?</div>
      <a href="tel:17" class="btn-urgence">
        <i class="fas fa-phone"></i>
        <div>
          <strong>Appeler le 17</strong>
          <span>Police Secours — 24h/24</span>
        </div>
      </a>
      <a href="tel:15" class="btn-urgence samu">
        <i class="fas fa-ambulance"></i>
        <div>
          <strong>Appeler le 15</strong>
          <span>SAMU — Urgences médicales</span>
        </div>
      </a>
    </div>

    <!-- NUMÉROS D'AIDE -->
    <div class="aide-section">
      <h2><i class="fas fa-phone-alt"></i> Numéros d'aide</h2>
      <div class="aide-cards">

        <div class="aide-card violet">
          <div class="aide-card-icon"><i class="fas fa-heart"></i></div>
          <div class="aide-card-info">
            <strong>3919</strong>
            <span>Violences Femmes Info</span>
            <p>Gratuit, anonyme, 24h/24. Écoute et orientation pour les victimes de violences.</p>
          </div>
          <a href="tel:3919" class="btn-appeler">Appeler</a>
        </div>

        <div class="aide-card rose">
          <div class="aide-card-icon"><i class="fas fa-child"></i></div>
          <div class="aide-card-info">
            <strong>119</strong>
            <span>Enfance en Danger</span>
            <p>Gratuit, 24h/24. Pour signaler une situation d'enfant en danger.</p>
          </div>
          <a href="tel:119" class="btn-appeler">Appeler</a>
        </div>

        <div class="aide-card vert">
          <div class="aide-card-icon"><i class="fas fa-hands-helping"></i></div>
          <div class="aide-card-info">
            <strong>0800 05 95 95</strong>
            <span>France Victimes</span>
            <p>Gratuit, 9h-19h. Accompagnement juridique et psychologique.</p>
          </div>
          <a href="tel:0800059595" class="btn-appeler">Appeler</a>
        </div>

        <div class="aide-card bleu">
          <div class="aide-card-icon"><i class="fas fa-comments"></i></div>
          <div class="aide-card-info">
            <strong>Chat en ligne</strong>
            <span>arretonslesviolences.gouv.fr</span>
            <p>Discute en ligne avec un professionnel de façon anonyme et sécurisée.</p>
          </div>
          <a href="https://arretonslesviolences.gouv.fr" target="_blank" class="btn-appeler">Accéder</a>
        </div>

      </div>
    </div>

    <!-- CONSEILS SÉCURITÉ -->
    <div class="aide-section">
      <h2><i class="fas fa-lock"></i> Protège ta navigation</h2>
      <div class="securite-grid">
        <div class="securite-item">
          <i class="fas fa-history"></i>
          <div>
            <strong>Efface ton historique</strong>
            <p>Supprime l'historique de ton navigateur après chaque visite</p>
          </div>
        </div>
        <div class="securite-item">
          <i class="fas fa-user-secret"></i>
          <div>
            <strong>Navigation privée</strong>
            <p>Utilise le mode navigation privée pour ne laisser aucune trace</p>
          </div>
        </div>
        <div class="securite-item">
          <i class="fas fa-sign-out-alt"></i>
          <div>
            <strong>Déconnecte-toi</strong>
            <p>Déconnecte-toi de Mumpower après chaque utilisation</p>
          </div>
        </div>
        <div class="securite-item">
          <i class="fas fa-eye-slash"></i>
          <div>
            <strong>Mot de passe fort</strong>
            <p>Utilise un mot de passe que personne d'autre ne connaît</p>
          </div>
        </div>
      </div>
    </div>

    <!-- MESSAGE BIENVEILLANT -->
    <div class="aide-message">
      <i class="fas fa-heart"></i>
      <p>Tu mérites de vivre en sécurité et dans le respect. Quelle que soit ta situation, tu n'es pas seule. Mumpower est là pour toi 💜</p>
    </div>

  </main>

  <script>
    function quitterVite() {
      // Remplace l'historique et redirige vers Google
      window.location.replace("https://www.google.fr");
    }

    // Touche Échap pour quitter rapidement
    document.addEventListener("keydown", function(e) {
      if (e.key === "Escape") quitterVite();
    });
  </script>

</body>
</html>